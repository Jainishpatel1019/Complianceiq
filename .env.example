# ComplianceIQ — Environment Variables Template
# Copy to .env and fill in values. NEVER commit .env to git.

# ── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=complianceiq
POSTGRES_USER=complianceiq
POSTGRES_PASSWORD=changeme_strong_password

# ── Redis (Celery broker + Airflow backend) ─────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── Airflow ─────────────────────────────────────────────────────────────────
AIRFLOW__CORE__EXECUTOR=CeleryExecutor
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__CORE__FERNET_KEY=changeme_generate_with_python_cryptography
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW__WEBSERVER__SECRET_KEY=changeme_random_string
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=changeme

# ── Ollama ──────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_REASON_MODEL=mistral:7b
OLLAMA_CLASSIFY_MODEL=llama3.2:3b

# ── ChromaDB ────────────────────────────────────────────────────────────────
CHROMADB_HOST=chromadb
CHROMADB_PORT=8000
CHROMADB_COLLECTION=regulations

# ── FastAPI ─────────────────────────────────────────────────────────────────
API_SECRET_KEY=changeme_random_string
API_HOST=0.0.0.0
API_PORT=8080

# ── Frontend / CORS ─────────────────────────────────────────────────────────
# For local dev: leave as-is. For HF Spaces: set to your Space URL.
# e.g. https://jainishpatel1019-complianceiq.hf.space
FRONTEND_URL=http://localhost:3000
# Used during 'npm run build' for the HF deployment bundle:
VITE_API_URL=http://localhost:8081/api/v1

# ── MLflow ──────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://mlflow:5000

# ── External APIs (all free, no key required) ───────────────────────────────
FEDERAL_REGISTER_BASE_URL=https://www.federalregister.gov/api/v1
FDIC_BANKFIND_BASE_URL=https://banks.data.fdic.gov/api
SEC_EDGAR_BASE_URL=https://efts.sec.gov/LATEST/search-index
CFPB_BASE_URL=https://api.consumerfinance.gov/data/hmda

# ── Alerting (optional — leave blank to disable) ────────────────────────────
SLACK_WEBHOOK_URL=
ALERT_EMAIL=
